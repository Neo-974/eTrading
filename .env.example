# Copiez ce fichier en .env et remplissez les valeurs.

# Secret partagé avec TradingView pour valider les alertes webhook.
# Générez-en un avec : python3 -c "import secrets; print(secrets.token_urlsafe(32))"
WEBHOOK_SECRET=change-me

# Mot de passe du dashboard (utilisateur : admin).
DASHBOARD_PASSWORD=changeme

# Optionnel : clé API Anthropic pour l'assistant intégré (onglet "Assistant").
# Créez la vôtre sur https://console.anthropic.com/ — facturée à l'usage, distincte
# d'un abonnement Claude.ai. Laissez vide pour désactiver l'assistant.
ANTHROPIC_API_KEY=
