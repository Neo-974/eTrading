# ===== Mode =====
# TRADING_MODE: "demo" (trades simulés, aucun argent réel) ou "live"
TRADING_MODE=demo

# BROKER: "demo" | "mt5"  (mt5 fonctionne aussi pour VTMarkets via leurs serveurs MT5)
BROKER=demo

# ===== Compte simulé (mode demo) =====
DEMO_ACCOUNT_BALANCE=10000

# ===== MetaTrader 5 / VTMarkets =====
# VTMarkets fournit des serveurs MT5 : renseigne ici les identifiants de ton
# compte VTMarkets (démo ou réel) une fois prêt à connecter le broker.
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=          # ex VTMarkets: "VTMarkets-Demo" ou "VTMarkets-Live 2"
# Chemin de l'exécutable Python qui a le package MetaTrader5 installé
PYTHON_BIN=python3
MT5_BRIDGE_PATH=./python/mt5_bridge.py

# ===== Supabase =====
SUPABASE_URL=
SUPABASE_KEY=

# ===== APIs externes =====
NEWSAPI_KEY=
COINGECKO_API=https://api.coingecko.com/api/v3

# ===== Notifications =====
DISCORD_WEBHOOK_URL=

# ===== Serveur =====
PORT=3001
# Origine autorisée pour le CORS (frontend)
CORS_ORIGIN=http://localhost:3000
